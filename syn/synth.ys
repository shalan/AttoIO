# Yosys synthesis script for the AttoIO macro.
# Target:  sky130_fd_sc_hd, TT 1.80V 25C.
# Output:  build/attoio_macro.syn.v  — gate-level netlist including the
#          FULL (non-blackbox) DFFRAM subtree generated by sky130_gen_dffram.

# ------------------------------------------------------------------
# 0. Defines matching the simulation flags
# ------------------------------------------------------------------
verilog_defines -DNRV_SINGLE_PORT_REGF
verilog_defines -DNRV_SHARED_ADDER
verilog_defines -DNRV_SERIAL_SHIFT

# ------------------------------------------------------------------
# 1. Read the sky130 liberty as blackbox stubs so the DFFRAM netlist's
#    sky130_fd_sc_hd__* cells are recognized.
# ------------------------------------------------------------------
read_liberty -lib LIBERTY_PATH

# ------------------------------------------------------------------
# 2. Read the generated DFFRAM netlist (RAM128, RAM32 + submodules),
#    and the parameterized DFFRAM wrapper.
# ------------------------------------------------------------------
read_verilog -sv models/dffram_gen/dffram_combined.nl.v
read_verilog -sv models/dffram_gen/dffram_wrapper.v

# Preserve the DFFRAM subtree through flatten / opt / abc so the
# generator's hand-crafted structure is not remapped.
setattr -mod -set keep_hierarchy 1 DFFRAM
setattr -mod -set keep_hierarchy 1 RAM128
setattr -mod -set keep_hierarchy 1 RAM32

# ------------------------------------------------------------------
# 3. Read the design RTL
# ------------------------------------------------------------------
read_verilog -sv rtl/attoio_memmux.v
read_verilog -sv rtl/attoio_gpio.v
read_verilog -sv rtl/attoio_ctrl.v
read_verilog -sv rtl/attoio_spi.v
read_verilog -sv rtl/attoio_timer.v
read_verilog -sv rtl/attoio_wdt.v
read_verilog -sv rtl/attoio_apb_if.v
read_verilog -sv rtl/attoio_macro.v
read_verilog -sv ../frv32/rtl/attorv32.v

# ------------------------------------------------------------------
# 4. Elaborate
# ------------------------------------------------------------------
hierarchy -check -top attoio_macro

# ------------------------------------------------------------------
# 5. Generic synthesis (flatten everything EXCEPT the DFFRAM subtree)
# ------------------------------------------------------------------
synth -top attoio_macro -flatten

# ------------------------------------------------------------------
# 6. Map glue-logic flip-flops and comb-logic to sky130_fd_sc_hd.
#    The DFFRAM cells are already mapped by the generator and are
#    shielded by keep_hierarchy.
# ------------------------------------------------------------------
dfflibmap -liberty LIBERTY_PATH
abc -D 13333 -liberty LIBERTY_PATH -script syn/abc.script
clean -purge

# ------------------------------------------------------------------
# 7. Report
# ------------------------------------------------------------------
stat -liberty LIBERTY_PATH -top attoio_macro
tee -o build/syn_check.log check

# ------------------------------------------------------------------
# 8. Write netlist (include DFFRAM subtree inline)
# ------------------------------------------------------------------
write_verilog -noattr -noexpr -nohex -nodec build/attoio_macro.syn.v
